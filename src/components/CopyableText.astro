---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="copyable">
  <span class="copyable-value">{text}</span>
  <span class="copyable-icon" aria-hidden="true">
    <svg
      class="icon-copy"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg
      class="icon-check"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    <span class="icon-error" role="img" aria-label="コピー失敗">⚠️</span>
  </span>
</span>

<script>
  document.querySelectorAll<HTMLElement>(".copyable").forEach((el) => {
    el.addEventListener("click", async () => {
      const value =
        el.querySelector(".copyable-value")?.textContent?.trim() ?? "";
      let success = false;
      try {
        await navigator.clipboard.writeText(value);
        success = true;
      } catch {}
      el.classList.add(success ? "copied" : "copy-failed");
      setTimeout(
        () => el.classList.remove(success ? "copied" : "copy-failed"),
        1500,
      );
    });
  });
</script>

<style>
  .copyable {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .copyable-value {
    font-family: monospace;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-color: color-mix(in srgb, currentColor 40%, transparent);
  }

  .copyable:hover .copyable-value {
    text-decoration-color: currentColor;
  }

  .copyable-icon {
    display: flex;
    align-items: center;
    opacity: 0.45;
  }

  .icon-check,
  .icon-error {
    display: none;
  }

  .copyable.copied .icon-copy,
  .copyable.copy-failed .icon-copy {
    display: none;
  }

  .copyable.copied .icon-check {
    display: block;
  }

  .copyable.copy-failed .icon-error {
    display: inline-flex;
    position: relative;
    font-size: 0.85rem;
    line-height: 1;
    cursor: help;
  }

  .copyable.copy-failed .icon-error::after {
    content: "許可設定を確認してください";
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #3d2a18;
    color: #f0e8d8;
    font-size: 0.7rem;
    white-space: nowrap;
    padding: 0.3rem 0.55rem;
    border-radius: 0.35rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .copyable.copy-failed .icon-error::before {
    content: "";
    position: absolute;
    bottom: calc(100% + 1px);
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #3d2a18;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .copyable.copy-failed .icon-error:hover::after,
  .copyable.copy-failed .icon-error:hover::before {
    opacity: 1;
  }

  .copyable.copied .copyable-icon,
  .copyable.copy-failed .copyable-icon {
    opacity: 0.8;
  }
</style>
