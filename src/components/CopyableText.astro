---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="copyable">
  <span class="copyable-value">{text}</span>
  <span class="copyable-icon" aria-hidden="true">
    <svg
      class="icon-copy"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg
      class="icon-check"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </span>
</span>

<script>
  document.querySelectorAll<HTMLElement>(".copyable").forEach((el) => {
    el.addEventListener("click", async () => {
      const value =
        el.querySelector(".copyable-value")?.textContent?.trim() ?? "";
      await navigator.clipboard.writeText(value);
      el.classList.add("copied");
      setTimeout(() => el.classList.remove("copied"), 1500);
    });
  });
</script>

<style>
  .copyable {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .copyable-value {
    font-family: monospace;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-color: color-mix(in srgb, currentColor 40%, transparent);
  }

  .copyable:hover .copyable-value {
    text-decoration-color: currentColor;
  }

  .copyable-icon {
    display: flex;
    align-items: center;
    opacity: 0.45;
  }

  .icon-check {
    display: none;
  }

  .copyable.copied .icon-copy {
    display: none;
  }

  .copyable.copied .icon-check {
    display: block;
  }

  .copyable.copied .copyable-icon {
    opacity: 0.8;
  }
</style>
