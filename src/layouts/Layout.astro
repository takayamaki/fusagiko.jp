---
import { ClientRouter } from "astro:transitions";
import "the-new-css-reset/css/reset.css";
import "@fontsource/m-plus-rounded-1c";
import "@fontsource/m-plus-rounded-1c/700.css";
import "../styles/transitions.css";
import ogInfo from "../og_info.json";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "fusagiko", description = "フサギコのウェブサイト" } =
  Astro.props;

const ogImageUrl = new URL("/og-image.png", ogInfo.url).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogInfo.type} />
    <meta property="og:url" content={ogInfo.url} />
    <meta property="og:site_name" content={ogInfo.site_name} />
    <meta property="og:locale" content={ogInfo.locale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/vnd.microsoft.icon" href="/favicon.ico" />
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  // :root[attr] ::view-transition-* の先祖セレクタはChromeで機能しないため
  // CSS カスタムプロパティ経由でアニメーション名を切り替える
  // data-direction は「どちら方向へ移動するか」を示す
  // left (Engineeringへ): 古いページは右へ退場、新しいページは左から登場
  const animMap: Record<string, [string, string]> = {
    left: ["slide-out-right", "slide-in-right"],
    right: ["slide-out-left", "slide-in-left"],
    up: ["slide-out-down", "slide-in-down"],
    down: ["slide-out-up", "slide-in-up"],
  };

  const reverseDir: Record<string, string> = {
    left: "right",
    right: "left",
    up: "down",
    down: "up",
  };

  let pendingDirection: string | null = null;

  function setDirectionVars(direction: string | null) {
    const root = document.documentElement;
    if (direction && animMap[direction]) {
      const [oldAnim, newAnim] = animMap[direction];
      root.style.setProperty("--vt-old", oldAnim);
      root.style.setProperty("--vt-new", newAnim);
    } else {
      root.style.removeProperty("--vt-old");
      root.style.removeProperty("--vt-new");
    }
  }

  document.addEventListener("click", (e) => {
    const link = (e.target as Element).closest("a[data-direction]");
    if (!link) return;
    const dir = (link as HTMLElement).dataset.direction ?? null;
    pendingDirection = dir;
    if (dir) {
      const from = location.href;
      const href = (link as HTMLAnchorElement).href;
      // ブラウザ戻る/進む用に URL ペアと方向を記憶しておく
      sessionStorage.setItem(`vt:${from}|${href}`, dir);
      sessionStorage.setItem(`vt:${href}|${from}`, reverseDir[dir] ?? dir);
    }
  });

  // startViewTransition 呼び出し前に設定する (after-preparation はその直前に発火)
  // ブラウザ戻る/進む時は click が発火しないため sessionStorage から方向を復元する
  document.addEventListener("astro:before-preparation", (e) => {
    if (pendingDirection === null) {
      const event = e as unknown as { from: URL; to: URL };
      const stored = sessionStorage.getItem(
        `vt:${event.from.href}|${event.to.href}`,
      );
      pendingDirection = stored ?? null;
    }
  });

  document.addEventListener("astro:after-preparation", () => {
    setDirectionVars(pendingDirection);
  });

  // DOMスワップで inline style もリセットされる可能性があるためスワップ後にも再設定
  document.addEventListener("astro:after-swap", () => {
    setDirectionVars(pendingDirection);
  });

  // data-astro-transition はアニメーション完了後(finished解決後)に削除される
  new MutationObserver(() => {
    if (!document.documentElement.hasAttribute("data-astro-transition")) {
      setDirectionVars(null);
      pendingDirection = null;
    }
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-astro-transition"],
  });
</script>

<style is:global>
  :root {
    --color-base: #6b7c41;
    --color-sub: #2e1a0e;
    --color-passion: #660b1b;
    --color-hero-bg: #c8f5b0;
    --color-hero-fg: #2a8c42;
    --color-surface: #3d2a18;
    --color-text: #f0e8d8;
  }

  body {
    font-family: "M PLUS Rounded 1c", sans-serif;
    background-color: var(--color-base);
    color: var(--color-text);
    min-height: 100vh;
  }

  a {
    color: var(--color-text);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
