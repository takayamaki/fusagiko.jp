---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PageShell from "../components/PageShell.astro";
import Section from "../components/Section.astro";

const articles = (await getCollection("engineering")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
  title="Engineering | fusagiko"
  description="fusagiko の Engineering ページ"
>
  <PageShell backHref="/" backDirection="right" title="Engineering">
    <p class="subtitle" slot="subtitle">
      Ruby / TypeScript / React / Terraform / AWS
    </p>

    {
      articles.length > 0 ? (
        <Section title="記事">
          <ul class="article-list">
            {articles.map((article) => (
              <li>
                <a
                  href={`/engineering/${article.id.replace(/\.md$/, "")}`}
                  data-direction="left"
                  class="article-link"
                >
                  <time datetime={article.data.date.toISOString()}>
                    {article.data.date.toLocaleDateString("ja-JP", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  <span class="article-title">{article.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </Section>
      ) : (
        <p class="empty">記事は準備中です。</p>
      )
    }
  </PageShell>
</Layout>

<style>
  .subtitle {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.8;
    letter-spacing: 0.03em;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-text) 20%, transparent);
    transition: opacity 0.15s;
  }

  .article-link:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  time {
    font-size: 0.75rem;
    opacity: 0.55;
    letter-spacing: 0.03em;
    color: var(--color-text);
  }

  .article-title {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .empty {
    color: var(--color-text);
    opacity: 0.5;
  }
</style>
