---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <section class="card">
      <img src="/icon.png" alt="fusagiko のアイコン" class="icon" />
      <h1>fusagiko</h1>
      <ul class="sns-links">
        <li>
          <a
            href="https://twitter.com/fusagiko"
            target="_blank"
            rel="noopener"
            aria-label="X (Twitter)"
          >
            <!-- X (Twitter) -->
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="24"
              height="24"
              aria-hidden="true"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://github.com/takayamaki"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
          >
            <!-- GitHub -->
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="24"
              height="24"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://imastodon.net/@fusagiko"
            target="_blank"
            rel="noopener"
            aria-label="Mastodon"
          >
            <!-- Mastodon -->
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="24"
              height="24"
              aria-hidden="true"
            >
              <path
                d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054c1.517.363 3.072.546 4.632.546.376 0 .75 0 1.125-.01 1.57-.044 3.224-.124 4.768-.422.038-.008.077-.015.11-.024 2.435-.464 4.753-1.92 4.989-5.604.008-.145.03-1.52.03-1.67.002-.512.167-3.63-.024-5.545zm-3.748 9.195h-2.561V8.29c0-1.309-.55-1.976-1.67-1.976-1.23 0-1.846.79-1.846 2.35v3.403h-2.546V8.663c0-1.56-.617-2.35-1.848-2.35-1.112 0-1.668.668-1.67 1.977v6.218H4.822V8.102c0-1.31.337-2.35 1.011-3.12.696-.77 1.608-1.164 2.74-1.164 1.311 0 2.302.5 2.962 1.509l.638 1.07.638-1.07c.66-1.01 1.65-1.509 2.96-1.509 1.13 0 2.043.395 2.74 1.164.675.77 1.012 1.81 1.012 3.12z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://bsky.app/profile/fusagiko.jp"
            target="_blank"
            rel="noopener"
            aria-label="Bluesky"
          >
            <!-- Bluesky -->
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="24"
              height="24"
              aria-hidden="true"
            >
              <path
                d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"
              ></path>
            </svg>
          </a>
        </li>
        <li>
          <a
            href="https://fusagiko.hatenablog.jp/"
            target="_blank"
            rel="noopener"
            aria-label="はてなブログ"
          >
            <!-- ノート/メモアイコン -->
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              width="24"
              height="24"
              aria-hidden="true"
            >
              <path
                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
              ></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </a>
        </li>
      </ul>
    </section>

    <nav class="axis-nav">
      <a href="/engineering" data-direction="left" class="axis-link axis-left">
        <div class="axis-content">
          <span class="arrow">←</span>
          <span class="axis-body">
            <span class="label">Engineering</span>
            <span class="tags">
              <span class="tag">Ruby</span>
              <span class="tag">TypeScript</span>
              <span class="tag">React</span>
              <span class="tag">Terraform</span>
              <span class="tag">AWS</span>
            </span>
          </span>
        </div>
      </a>
      <a href="/idolmaster" data-direction="down" class="axis-link axis-down">
        <div class="axis-content">
          <span class="label">THE IDOLM@STER</span>
          <span class="arrow">↓</span>
        </div>
      </a>
      <a href="/creative" data-direction="right" class="axis-link axis-right">
        <div class="axis-content">
          <span class="axis-body">
            <span class="label">Creative</span>
            <span class="tags">
              <span class="tag">DJ</span>
              <span class="tag">VJ</span>
            </span>
          </span>
          <span class="arrow">→</span>
        </div>
      </a>
    </nav>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 3rem;
    padding: 2rem;
    view-transition-name: main-content;
  }

  .card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    background-color: var(--color-hero-bg);
    color: var(--color-sub);
    padding: 2.5rem 3.5rem;
    border-radius: 1rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  .icon {
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    object-fit: cover;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-sub);
  }

  .sns-links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin-top: 0.5rem;
  }

  .sns-links a {
    color: var(--color-sub);
    opacity: 0.75;
    transition: opacity 0.15s;
  }

  .sns-links a:hover {
    opacity: 1;
    text-decoration: none;
  }

  .axis-nav {
    display: flex;
    gap: 2rem;
    align-items: stretch;
  }

  .axis-left,
  .axis-right {
    flex: 1;
  }

  .axis-link {
    display: flex;
    padding: 0.75rem 1.25rem;
    border: 2px solid var(--color-text);
    border-radius: 0.5rem;
    color: var(--color-text);
    font-size: 1rem;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .axis-link:hover {
    background-color: var(--color-text);
    color: var(--color-base);
    text-decoration: none;
  }

  .axis-left,
  .axis-right,
  .axis-down {
    justify-content: center;
    align-items: center;
  }

  .axis-right .axis-body {
    align-items: flex-end;
  }

  .axis-down .axis-content {
    flex-direction: column;
    text-align: center;
  }

  .axis-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .axis-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .arrow {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    border: 1px solid currentColor;
    border-radius: 0.25rem;
    opacity: 0.7;
  }
</style>
